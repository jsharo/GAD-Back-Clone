# ── Base de datos ─────────────────────────────────────────────
# Cadena de conexión PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/gad_canar"

# ── JWT ───────────────────────────────────────────────────────
# Secreto del access token (cámbialo por algo largo y aleatorio en producción)
JWT_SECRET="cambia_este_secreto_en_produccion"
JWT_EXPIRES_IN="15m"

# Secreto del refresh token (debe ser diferente al access token)
JWT_REFRESH_SECRET="cambia_este_refresh_secreto_en_produccion"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────
# URL del frontend en desarrollo
FRONTEND_URL="http://localhost:5173"

# ── Archivos / Uploads ────────────────────────────────────────
# Carpeta local donde se guardarán los archivos subidos
UPLOAD_DIR="./uploads"
# Tamaño máximo de archivo en bytes (10 MB)
MAX_FILE_SIZE=10485760
