DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gad_canar_dev?schema=public"
JWT_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME="GAD Municipal de Cañar"

IPFS_ENABLED=false
IPFS_PROVIDER=disabled
IPFS_API_URL=
IPFS_API_KEY=
IPFS_API_SECRET=
IPFS_JWT=
IPFS_GATEWAY_URL=
IPFS_UPLOAD_MODE=manual

# Development may use .env. Production secrets must come from Vault, KMS,
# Secret Manager, or an equivalent system. Never commit a real private key.
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_PROVIDER=disabled
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_CHAIN_ID=
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_NETWORK_NAME=local

# Verificacion local de firmas PDF con PyHanko. El script de instalacion crea
# .venv-signatures dentro del backend; esta ruta puede sobrescribirse en deploy.
SIGNATURE_PYTHON_EXECUTABLE=
SIGNATURE_TRUST_ROOTS=
SIGNATURE_ALLOW_NETWORK=false
SIGNATURE_VERIFIER_TIMEOUT_MS=20000
