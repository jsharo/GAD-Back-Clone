{
  "info": {
    "name": "GAD Cañar API",
    "description": "Colección para probar auth, users, verification y roles.\n\nBase URL: http://localhost:3000/api/v1\nSwagger: http://localhost:3000/api/docs\n\nAdmin seed: admin@gadcanar.gob.ec / Admin123*\n\nEl código de verificación aparece en la consola del servidor (EmailService log).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gadcanar.gob.ec\",\n  \"password\": \"Admin123*\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register Citizen",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ciudadano@test.ec\",\n  \"password\": \"Test123456\",\n  \"cedula\": \"0302145896\",\n  \"name\": \"Juan\",\n  \"lastname\": \"Pérez\"\n}"
            },
            "url": "{{baseUrl}}/users/register"
          }
        },
        {
          "name": "Register Architect",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"arquitecto@test.ec\",\n  \"password\": \"Arch123456\",\n  \"cedula\": \"0302145897\",\n  \"name\": \"María\",\n  \"lastname\": \"López\"\n}"
            },
            "url": "{{baseUrl}}/users/register-architect"
          }
        },
        {
          "name": "List Users (Admin/Secretary)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/users/:id"
          }
        },
        {
          "name": "Create Institutional User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tecnico@gadcanar.gob.ec\",\n  \"password\": \"Tecnico123\",\n  \"cedula\": \"0302145898\",\n  \"name\": \"Carlos\",\n  \"lastname\": \"Técnico\",\n  \"roleName\": \"TECHNICIAN\"\n}"
            },
            "url": "{{baseUrl}}/users/institutional"
          }
        }
      ]
    },
    {
      "name": "Verification",
      "item": [
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ciudadano@test.ec\",\n  \"code\": \"000000\"\n}"
            },
            "url": "{{baseUrl}}/verification/verify-email"
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/roles"
          }
        },
        {
          "name": "List Permissions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/roles/permissions"
          }
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/audit"
          }
        }
      ]
    }
  ]
}
