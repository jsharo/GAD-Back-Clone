{
  "name": "gad-canar-backend",
  "version": "1.0.0",
  "description": "Backend API del Sistema de Gestión de Trámites — GAD Municipal de Cañar",
  "author": "GAD Municipal de Cañar",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "node dist/src/main",
    "start:prod": "prisma migrate deploy && prisma db seed && node dist/src/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:critical": "npm run build && node --test test/document-security.test.js test/critical/critical-backend.test.js",
    "signatures:setup": "node scripts/setup.signature.verifier.js",
    "test:signatures": "npm run signatures:setup && npm run build && node --test test/signature.verification.test.js",
    "demo:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/demo/preflight.ps1",
    "demo:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/demo/start-demo.ps1",
    "demo:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/demo/check-demo.ps1",
    "demo:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/demo/stop-demo.ps1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@prisma/client": "^5.14.0",
    "@sendgrid/mail": "^8.1.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "ethers": "^6.17.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "hardhat": "^2.28.0",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
